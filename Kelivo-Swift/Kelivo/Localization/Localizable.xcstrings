    "assistantProviderSampleAssistantSystemPrompt": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You are %1$@, an AI assistant who gladly provides accurate and helpful assistance. The current time is %2$@, the device language is %3$@, timezone is %4$@, the user is using %5$@, version %6$@. If the user does not explicitly specify otherwise, please use the user's device language when replying."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "你是%1$@, 一个人工智能助手，乐意为用户提供准确，有益的帮助。现在时间是%2$@，用户设备语言为%3$@，时区为%4$@，用户正在使用%5$@，版本%6$@。如果用户没有明确说明，请使用用户设备语言进行回复。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "你是%1$@, 一個人工智慧助理，樂意為使用者提供準確，有益的幫助。現在時間是%2$@，使用者裝置語言為%3$@，時區為%4$@，使用者正在使用%5$@，版本%6$@。如果使用者沒有明確說明，請使用使用者裝置語言進行回覆。"
          }
        }
      }
    },
